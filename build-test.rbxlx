			itemType = Keys.ItemType.egg,
			itemName = "Season1Egg",
			count = 8
		},
	},
	-- level19
	{
		exp = 4100,
		Free = {
			text = "x3",
			title = "Wins Potion",
			tier = "Gold",
			itemType = Keys.ItemType.potion,
			itemName = "wins1Potion30",
