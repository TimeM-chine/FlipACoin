end

function NPCSystem:PlayerAdded(sender, player, args)
	if IsServer then
		if sender ~= SENDER then
			return
		end

		self.Client:PlayerAdded(player, args)
	else
		NPCUi = require(script.ui)
		NPCUi.Init()
	end
end

return NPCSystem
]]></string>
