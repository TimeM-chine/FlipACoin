		-- 	if descendant:IsA("BasePart") then
		-- 		if partNonZeroTransparencyValues[descendant.Name] ~= nil then
		-- 			descendant.Transparency = partNonZeroTransparencyValues[descendant.Name]
		-- 		else
		-- 			descendant.Transparency = 0
