		},
	},
	-- level20
	{
		exp = 5000,
		Free = {
			text = "",
			title = "The Prophecy",
			tier = "Blue",
			itemType = Keys.ItemType.pet,
			itemName = "The Prophecy",
			count = 1
		},
		Premium = {
			text = "",
