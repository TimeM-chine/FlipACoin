    <Item class="Folder" referent="224">
      <Properties>
        <string name="Name">Packages</string>
      </Properties>
      <Item class="ModuleScript" referent="225">
        <Properties>
          <string name="Name">Fusion</string>
          <string name="Source"><![CDATA[return require(script.Parent._Index["elttob_fusion@0.2.0"]["fusion"])
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="226">
        <Properties>
          <string name="Name">SimpleDialogue</string>
          <string name="Source"><![CDATA[return require(script.Parent._Index["crabzzai_simpledialogue@0.2.1"]["simpledialogue"])
]]></string>
        </Properties>
      </Item>
      <Item class="Folder" referent="227">
        <Properties>
          <string name="Name">_Index</string>
