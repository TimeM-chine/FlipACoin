            <string name="Source">local SettingPresets = {}

SettingPresets.Default = {
    bgm = 1,
    sfx = 1,
    showMyPets = true,
    showOtherPets = true,
    autoHatchNum = 1,
    trade = true,
}

return SettingPresets</string>
